# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App secret for signing anonymous session tokens (generate a random 32+ char string)
ANON_TOKEN_SECRET=change-this-to-a-random-secret-32chars-minimum

# App URL (used for generating short links)
NEXT_PUBLIC_APP_URL=https://linnn.kr

# Optional: CAPTCHA provider (placeholder for future integration)
# NEXT_PUBLIC_HCAPTCHA_SITE_KEY=
# HCAPTCHA_SECRET_KEY=
